{
  "data_file": "llm_bayesian_reasoning/data/preprocessed_data/parsed_test.jsonl",
  "results_root": "results",
  "retrieval_cache_dir": "llm_bayesian_reasoning/data/retrieval_cache",
  "use_metadata_ground_truth": true,
  "mlflow_experiment": "bm25-suite",
  "retrievers": [
    {
      "name": "bm25-main",
      "retriever_type": "BM25",
      "index_path": "index/bm25",
      "documents_path": "llm_bayesian_reasoning/data/index_data/documents.jsonl",
      "retrieval_pool_size": 50
    }
  ],
  "variants": [
    {
      "name": "bm25_tf_ctx",
      "retriever_name": "bm25-main",
      "top_n": 50,
      "top_k": 10,
      "logic_backend": "ProbLog",
      "estimator_config": {
        "model_name": "meta-llama/Llama-3.1-8B-Instruct",
        "device": "cuda",
        "estimator_type": "TrueFalseLLM",
        "include_retrieved_text": true,
        "quantization": {
          "load_in_4bit": true,
          "bnb_4bit_quant_type": "nf4",
          "bnb_4bit_compute_dtype": "torch.float16"
        }
      }
    }
  ]
}